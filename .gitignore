# ==============================
# 1. Python 开发与环境配置 (数据分析/深度学习)
# ==============================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# 虚拟环境文件夹（如果你在项目下建了环境）
venv/
env/
.conda/
# 环境变量与机密配置
.env
.env.local

# ==============================
# 2. Web 开发 (React, CesiumJS 等前端框架)
# ==============================
node_modules/
dist/
build/
.next/
# npm 或 yarn 报错日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================
# 3. MkDocs 知识库项目
# ==============================
# MkDocs 在执行 build 或 gh-deploy 时自动生成的静态网页文件夹
site/

# ==============================
# 4. C 语言开发 (数据结构代码等)
# ==============================
# 编译生成的对象文件和可执行文件
*.o
*.obj
*.exe
*.out
*.app

# ==============================
# 5. 大型数据集与深度学习模型 (GIS / 海洋科研 / GeoAI)
# ==============================
# 避免将动辄几个G的栅格、矢量数据或深度学习权重文件推送到 GitHub
*.tif
*.tiff
*.shp
*.shx
*.dbf
*.nc       # NetCDF 数据文件
*.h5       # HDF5 模型或数据文件
*.pth      # PyTorch 训练出来的模型权重
*.pt
data/      # 如果你习惯把数据统一放在根目录的 data 文件夹里，可以直接忽略整个文件夹

# ==============================
# 6. 操作系统生成的隐藏文件
# ==============================
.DS_Store
Thumbs.db